    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nconst seen = new Set();\nconst result = [];\n\nfor (const item of $input.all()) {\n\n  const urls = item.json.url || [];\n\n  for (const u of urls) {\n\n    if (!seen.has(u)) {\n\n      seen.add(u);\n\n      result.push({\n        json: {\n          ...item.json,\n          url: u\n        }\n      });\n\n    }\n\n  }\n\n}\n\nreturn result;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -2000,
        240
      ],
      "id": "01caba2a-e145-4ee4-b141-6f747fd4e0c4",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nconst result = [];\n\nfor (const item of $input.all()) {\n\n  const scripts = item.json.metadata || [];\n\n  let description = null;\n  let publisher = null;\n  let publicationDate = null;\n\n  for (const script of scripts) {\n    try {\n      const data = JSON.parse(script);\n\n      if (data[\"@type\"] === \"Book\") {\n\n        description = data.description || description;\n        publicationDate = data.datePublished || publicationDate;\n\n        if (data.publisher) {\n          publisher = data.publisher.name || publisher;\n        }\n\n      }\n\n    } catch (e) {}\n  }\n\n  result.push({\n    json: {\n      ...item.json,\n      description,\n      publisher,\n      publicationDate\n    }\n  });\n\n}\n\nreturn result;"
      },
