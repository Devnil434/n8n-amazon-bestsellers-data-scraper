    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Clean and normalize the book data\nconst item = $input.item.json;\n\n// Extract numeric rating from text like '4.6 out of 5 stars'\nlet rating = null;\nconst ratingText = String(item.rating || \"\");\n\nif (typeof item.rating === 'string') {\n  const ratingMatch = ratingText.match(/([0-9.]+)\\s*out\\s*of\\s*5/i);\n  if (ratingMatch) {\n    rating = parseFloat(ratingMatch[1]);\n  }\n}\n\n// Extract numeric review count from text like '12,540 ratings'\nlet reviewCount = null;\nconst reviewsText = String(item.reviews || \"\");\n\nif (item.reviews) {\n  const reviewMatch = reviewsText.match(/([0-9,]+)\\s*ratings?/i);\n  if (reviewMatch) {\n    reviewCount = parseInt(reviewMatch[1].replace(/,/g, ''), 10);\n  }\n}\n\n// Remove commas from price and convert to number\nlet price = null;\nconst priceText = String(item.price || \"\");\n\nif (item.price) {\n  const priceMatch = priceText.match(/\\$?([0-9,.]+)/);\n  if (priceMatch) {\n    price = parseFloat(priceMatch[1].replace(/,/g, ''));\n  }\n}\n\n// Convert publication date to ISO format YYYY-MM-DD\nlet publicationDate = null;\nif (item.publicationDate) {\n  try {\n    const date = new Date(item.publicationDate);\n    if (!isNaN(date.getTime())) {\n      publicationDate = date.toISOString().split('T')[0];\n    }\n  } catch (e) {\n    publicationDate = item.publicationDate;\n  }\n}\n\n// Ensure URLs are complete absolute URLs\nlet url = item.url;\nif (url && !url.startsWith('http')) {\n  url = 'https://www.amazon.com' + (url.startsWith('/') ? url : '/' + url);\n}\n\n// Return cleaned and normalized data\nreturn {\n  rank: item.rank,\n  title: item.title,\n  author: item.author,\n  rating: rating,\n  reviewCount: reviewCount,\n  price: price,\n  url: url,\n  description: item.description,\n  publisher: item.publisher,\n  publicationDate: publicationDate\n};"
      },
